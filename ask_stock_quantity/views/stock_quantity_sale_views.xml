<odoo>
  <record id="sale_order_line_view_form_inherit_stock_quantity" model="ir.ui.view">
      <field name="name">sale.order.form.inherit.stock.quantity</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
          <xpath expr="//field[@name='order_line']/list/field[@name='qty_invoiced']" position="after">
              <field name="qty_available" optional="show"/>
          </xpath>
      </field>
  </record>
</odoo>
